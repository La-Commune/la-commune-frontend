# Supabase — obtén estos valores en supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HMAC key para firmar tokens de sesión de barista y cookies de cliente
# Usado por verifyAdminPin (COOKIE_SECRET fallback) y customerSession
ADMIN_HMAC_KEY=

# (Opcional) Build ID para cache-busting del Service Worker
NEXT_PUBLIC_BUILD_ID=
