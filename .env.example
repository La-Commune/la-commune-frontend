# Firebase — obtén estos valores en la consola de Firebase > Configuración del proyecto
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# PIN de acceso al panel de barista — nunca usar prefijo NEXT_PUBLIC_
ADMIN_PIN=

# HMAC key para firmar PINs y tokens de sesión
ADMIN_HMAC_KEY=

# Código de recuperación de emergencia (texto plano) — omitir si no se necesita
# Si está definido, permite acceso al panel aunque se olvide el PIN configurado
ADMIN_RECOVERY_CODE=
