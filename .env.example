# ══════════════════════════════════════════════
# La Commune Frontend — Environment Variables
# ══════════════════════════════════════════════
# Copia este archivo como .env.development o .env.production
# y llena los valores correspondientes.
#
# Scripts:
#   npm run dev          → usa .env.development (por defecto)
#   npm run dev:prod     → usa .env.production
#   npm run build        → usa .env.production
#   npm run build:dev    → usa .env.development
# ══════════════════════════════════════════════

# ── Supabase — obtén estos valores en supabase.com > Project Settings > API ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Negocio — ID del registro en tabla negocios ──
NEXT_PUBLIC_NEGOCIO_ID=

# ── Auth ──
# HMAC key para firmar cookies de sesión barista y tokens de cliente
# Si no está definido en dev, se genera uno aleatorio por proceso
ADMIN_HMAC_KEY=

# (Solo development) Secret para hash de PIN de clientes
PIN_HASH_SECRET=

# ── Push Notifications ──
# VAPID keys para Web Push — generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── (Opcional) Build ID para cache-busting del Service Worker ──
NEXT_PUBLIC_BUILD_ID=
